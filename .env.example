SUPABASE_URL=
SUPABASE_KEY=

OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=bge-m3
EMBED_DIM=1024
# qwen3:4b & qwen3.5:4b rejected for 4GB VRAM (thinking models; Ollama ignores
# think=False -> empty content 33-55%; CPU offload ~400-600s/answer). See PRD.
DEFAULT_MODEL=qwen2.5:3b-instruct
FAST_MODEL=qwen2.5:3b-instruct
NUM_CTX=8192
TESSERACT_CMD=
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
VLM_MODEL=moondream
PDF_PATH=data/bki_hull_2026.pdf

RERANKER_MAX_LENGTH=512
TRANSLATE_MAX_TOKENS=200
EXPAND_N_QUERIES=2
GUARDRAIL_TOP_GAP=0.5
GUARDRAIL_MIN_TOP_SCORE=-2.0
