# Python build artifacts
*.egg-info/
__pycache__/
*.pyc
.eggs/
build/
dist/

# Virtual env
.venv/

# Test cache
.pytest_cache/

# Local data (PDFs are large; not tracked)
data/*.pdf

# Test / debug artifacts (created by scripts and ad-hoc shell invocations)
*.log
*.err
*.xml
out.txt

# Throwaway benchmark / probe artifacts
bench_resp_*.json
probe_answer*.txt
phase3_*.xml
phase3_*_proc.xml

# Temporary files and folders
temp/

# Env / secrets
.env

# Internal / planning documents (not for commit)
AGENTS.md
HANDOFF.md
PRD*.md
commit-rules.md
handoff-fase*.md

# Ad-hoc demo / exploratory content (CLI experiments, not shipped code)
demos/

# Ad-hoc / private script helpers (underscore-prefixed)
scripts/_*.py

# Throwaway eval-run transcripts (created by ad-hoc shell invocations)
golden_run*.txt
holdout_run*.txt
v2_run4.txt
golden_post018*.txt
v1_post018.txt
v2_post018.txt
